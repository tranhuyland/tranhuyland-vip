import { getGoogleSheetData } from '../utils';
import Link from 'next/link';

export async function generateStaticParams() {
  const data = await getGoogleSheetData();
  // Ép buộc hệ thống sinh đường link tĩnh dựa hoàn toàn vào cột ID trong file Sheets của anh
  return data.map((item) => ({
    slug: item.id ? item.id.toString() : '',
  }));
}

export async function generateMetadata({ params }) {
  const data = await getGoogleSheetData();
  const item = data.find(i => i.id.toString() === params.slug);
  
  if (!item) return { title: 'Không tìm thấy sản phẩm | Trần Huy Land' };
  
  return {
    title: `${item.tieude || 'Nhà đất'} | Trần Huy Land`,
    description: `Giá bán: ${item.gia || 'Thỏa thuận'}. Vị trí: ${item.khuVucFull || 'Đà Nẵng'}.`,
  };
}

export default async function PropertyDetail({ params }) {
  const data = await getGoogleSheetData();
  // Tìm kiếm căn nhà đất chính xác theo ID
  const item = data.find(i => i.id.toString() === params.slug);

