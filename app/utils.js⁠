import Papa from 'papaparse';

export async function getGoogleSheetData() {
  const sheetUrl = "https://docs.google.com/spreadsheets/d/1-LupBV6uNuUitz4vF6pFv6MupuVDMujafqhjQBNNPTA/export?format=csv";

  try {
    const res = await fetch(sheetUrl, {
      next: { revalidate: 300 } // Làm mới sau 5 phút
    });

    if (!res.ok) throw new Error("Không thể kết nối Google Sheets");

    let csvText = await res.text();
    
    // Xóa ký tự BOM ẩn phát sinh trên di động
    csvText = csvText.replace(/^\uFEFF/, '');

    // Sử dụng thư viện PapaParse để bóc tách Excel chuẩn quốc tế, chấp nhận mọi dấu phẩy bên trong ô mô tả
    const parsedData = Papa.parse(csvText, {
      header: true, // Tự động lấy dòng đầu tiên làm tên cột
      skipEmptyLines: true // Bỏ qua các dòng trống
    });

    const data = parsedData.data.map((item, rowIndex) => {
      // Làm sạch dữ liệu từng ô, xóa bỏ ký tự xuống dòng ẩn \r
      const cleanedItem = {};
      Object.keys(item).forEach(key => {
        const cleanKey = key.replace(/[\r\n\t]/g, "").trim();
        let cleanVal = item[key] ? item[key].toString().replace(/[\r\n\t]/g, "").trim() : "";
        cleanedItem[cleanKey] = cleanVal;
      });

      // Ép kiểu dữ liệu chuẩn khít
      if (!cleanedItem.id) {
        cleanedItem.id = (rowIndex + 1).toString();
      }

      return cleanedItem;
    });

    // Chỉ lấy các hàng thực sự có điền tiêu đề nhà đất
    return data.filter(item => item.id && item.tieude && item.tieude.length > 0);
  } catch (error) {
    console.error("Lỗi đồng bộ giỏ hàng:", error);
    return [];
  }
}
