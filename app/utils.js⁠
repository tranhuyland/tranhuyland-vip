export async function getGoogleSheetData() {
  // ĐÃ SỬA: Thay chính xác đường link trích xuất CSV gốc từ file index.html của anh
  const sheetUrl = "https://docs.google.com/spreadsheets/d/1-LupBV6uNuUitz4vF6pFv6MupuVDMujafqhjQBNNPTA/export?format=csv";

  try {
    // Tự động làm mới dữ liệu sau mỗi 5 phút (ISR)
    const res = await fetch(sheetUrl, {
      next: { revalidate: 300 }
    });

    if (!res.ok) throw new Error("Không thể tải dữ liệu từ Google Sheets");

    const csvText = await res.text();
    
    // Tách văn bản thành các dòng dữ liệu, bỏ dòng trống
    const lines = csvText.split('\n').map(line => line.trim()).filter(line => line.length > 0);
    if (lines.length <= 1) return [];

    // Lấy dòng tiêu đề đầu tiên và làm sạch các ký tự ẩn phiền toái
    const headers = lines[0].split(',').map(h => h.replace(/[\r\n\t\"\']/g, "").trim());

    // Chuyển đổi các dòng dữ liệu thành mảng đối tượng JSON
    const data = lines.slice(1).map((line, rowIndex) => {
      const values = [];
      let current = "";
      let inQuotes = false;

      // Thuật toán tách dấu phẩy chuẩn xác kể cả khi ô mô tả có chứa dấu phẩy bên trong ngoặc kép
      for (let i = 0; i < line.length; i++) {
        const char = line[i];
        if (char === '"') {
          inQuotes = !inQuotes;
        } else if (char === ',' && !inQuotes) {
          values.push(current.trim());
          current = "";
        } else {
          current += char;
        }
      }
      values.push(current.trim());

      const obj = {};
      headers.forEach((header, index) => {
        let val = values[index] || "";
        // Xóa bỏ dấu ngoặc kép bọc ngoài chuỗi dữ liệu nếu có
        if (val.startsWith('"') && val.endsWith('"')) {
          val = val.slice(1, -1);
        }
        // Làm sạch hoàn toàn ký tự xuống dòng ẩn trong ô
        val = val.replace(/[\r\n]/g, "").trim();

        // Ép kiểu dữ liệu chuẩn khít với file cấu hình của anh
        if (header === 'id') {
          obj[header] = parseInt(val) || (rowIndex + 1);
        } else if (header === 'soGia') {
          obj[header] = parseFloat(val) || 0;
        } else {
          obj[header] = val;
        }
      });

      return obj;
    });

    // Lọc bỏ hàng lỗi, bắt buộc phải có ID và Tiêu đề nhà đất thì mới hiển thị lên trang web
    return data.filter(item => item.id && item.tieude);
  } catch (error) {
    console.error("Lỗi đồng bộ giỏ hàng nhà đất:", error);
    return [];
  }
}
